# Supabase — copy to .env.local and fill in. Find these in your Supabase
# project: Settings > API. For local dev use the values printed by `supabase start`.

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to the client. Bypasses Row Level Security.
# Used by background analysis jobs that write metrics on behalf of users.
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket holding uploaded sprint videos.
NEXT_PUBLIC_SUPABASE_VIDEO_BUCKET=sprint-videos
